# GitHub API token with repo and admin:repo_hook scopes
GITHUB_TOKEN=ghp_your_token_here

# Secret for GitHub webhook verification (optional but recommended)
WEBHOOK_SECRET=your_webhook_secret_here

# Ngrok authentication token (required if using ngrok)
NGROK_AUTH_TOKEN=your_ngrok_token_here

# Anthropic API key for Claude models (recommended)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI API key (fallback if Anthropic is not available)
OPENAI_API_KEY=your_openai_key_here
